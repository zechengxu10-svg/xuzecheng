{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "FruitEntry": {
      "title": "FruitEntry",
      "description": "A fruit entry in the user's collection (identified via camera).",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "fruitName": { "type": "string" },
        "scientificName": { "type": "string" },
        "family": { "type": "string" },
        "origin": { "type": "string" },
        "nutrition": {
          "type": "object",
          "properties": {
            "calories": { "type": "string" },
            "vitamins": { "type": "array", "items": { "type": "string" } },
            "minerals": { "type": "array", "items": { "type": "string" } }
          }
        },
        "funFact": { "type": "string" },
        "season": { "type": "string" },
        "imageUrl": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "fruitName", "imageUrl", "timestamp"]
    },
    "FavoriteFruit": {
      "title": "FavoriteFruit",
      "description": "A fruit favorited by the user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "fruitName": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "fruitName", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles."
    },
    "/users/{userId}/collection/{entryId}": {
      "schema": "FruitEntry",
      "description": "User's identified fruits."
    },
    "/users/{userId}/favorites/{favoriteId}": {
      "schema": "FavoriteFruit",
      "description": "User's favorite fruits."
    }
  }
}
